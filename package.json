{
  "name": "homer-knowledge-study",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "node scripts/sync-provenance.mjs full && tsc && vite build",
    "build:public": "node scripts/build-public.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "audit:check": "node scripts/audit-check.mjs",
    "audit:full": "npm run build && node scripts/audit-full.mjs",
    "audit:public": "npm run build:public && node scripts/audit-public.mjs",
    "verify": "npm run audit:check && npm run audit:full && npm run audit:public && npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
